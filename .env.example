# ---------------------------------------------------------------
# Gradly — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ---------------------------------------------------------------

# Supabase — find these in: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# SERVICE ROLE key — starts with sb_secret_... (NOT sb_publishable_)
# Used only by server-side seed scripts. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ANON / public key — starts with sb_publishable_... (or eyJhbGci... for old JWT format)
# Safe to expose to the browser via the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
